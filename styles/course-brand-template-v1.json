{
  "id": "course-brand-template-v1",
  "name": "Course Brand Template v1",
  "status": "frontend-ready-foundation",
  "version": "1.0.0",
  "purpose": "Frontend-usable design system foundation for a brand-led course landing page.",
  "sourceFiles": {
    "cssTokens": "styles/tokens/course-brand.css",
    "layoutRules": "styles/layout-rules/landing-page.md",
    "typographyRules": "styles/typography/course-brand.md",
    "motionRules": "styles/motion/animation-style.md"
  },
  "scope": {
    "includes": [
      "hero system",
      "typography system",
      "spacing system",
      "motion system",
      "style rules",
      "layout rules",
      "animation rules"
    ],
    "excludes": [
      "SQL",
      "webhook",
      "form backend",
      "admin workflow",
      "worker jobs"
    ]
  },
  "tokens": {
    "color": {
      "ink": "var(--cb-color-ink)",
      "muted": "var(--cb-color-muted)",
      "subtle": "var(--cb-color-subtle)",
      "paper": "var(--cb-color-paper)",
      "surface": "var(--cb-color-surface)",
      "surfaceStrong": "var(--cb-color-surface-strong)",
      "brand": "var(--cb-color-brand)",
      "brandStrong": "var(--cb-color-brand-strong)",
      "accent": "var(--cb-color-accent)",
      "accentSoft": "var(--cb-color-accent-soft)",
      "line": "var(--cb-color-line)"
    },
    "typography": {
      "display": {
        "className": "cb-hero-title",
        "fontFamily": "var(--cb-font-display)",
        "fontSize": "var(--cb-text-hero)",
        "lineHeight": "var(--cb-leading-tight)",
        "fontWeight": "var(--cb-weight-bold)",
        "maxWidth": "9.5em"
      },
      "sectionTitle": {
        "className": "cb-section-title",
        "fontFamily": "var(--cb-font-display)",
        "fontSize": "var(--cb-text-section)",
        "lineHeight": "var(--cb-leading-title)",
        "fontWeight": "var(--cb-weight-bold)",
        "maxWidth": "11em"
      },
      "body": {
        "className": "cb-body",
        "fontFamily": "var(--cb-font-sans)",
        "fontSize": "var(--cb-text-body)",
        "lineHeight": "var(--cb-leading-body)",
        "fontWeight": "var(--cb-weight-regular)",
        "maxWidth": "var(--cb-content-narrow)"
      },
      "kicker": {
        "className": "cb-kicker",
        "fontSize": "var(--cb-text-label)",
        "lineHeight": "var(--cb-leading-caption)",
        "fontWeight": "var(--cb-weight-bold)",
        "textTransform": "uppercase"
      }
    },
    "spacing": {
      "scale": {
        "1": "var(--cb-space-1)",
        "2": "var(--cb-space-2)",
        "3": "var(--cb-space-3)",
        "4": "var(--cb-space-4)",
        "5": "var(--cb-space-5)",
        "6": "var(--cb-space-6)",
        "7": "var(--cb-space-7)",
        "8": "var(--cb-space-8)",
        "9": "var(--cb-space-9)",
        "10": "var(--cb-space-10)",
        "11": "var(--cb-space-11)"
      },
      "section": {
        "compact": "var(--cb-section-compact)",
        "standard": "var(--cb-section-standard)",
        "feature": "var(--cb-section-feature)",
        "hero": "var(--cb-hero-padding-block)"
      }
    },
    "motion": {
      "durations": {
        "micro": "var(--cb-duration-micro)",
        "fast": "var(--cb-duration-fast)",
        "standard": "var(--cb-duration-standard)",
        "reveal": "var(--cb-duration-reveal)",
        "hero": "var(--cb-duration-hero)"
      },
      "easing": {
        "default": "var(--cb-ease-default)",
        "sharp": "var(--cb-ease-sharp)",
        "gentle": "var(--cb-ease-gentle)"
      },
      "stagger": {
        "tight": "var(--cb-stagger-tight)",
        "standard": "var(--cb-stagger-standard)",
        "wide": "var(--cb-stagger-wide)"
      }
    }
  },
  "components": {
    "page": {
      "className": "cb-page",
      "rule": "Apply to the page root so typography and color roles inherit consistently."
    },
    "shell": {
      "className": "cb-shell",
      "rule": "Use as the page width container for all sections."
    },
    "hero": {
      "className": "cb-hero",
      "requiredChildren": [
        "cb-hero__grid",
        "cb-hero__content",
        "cb-hero-title",
        "cb-hero__actions",
        "cb-hero__visual"
      ],
      "layout": {
        "desktop": "Two-column asymmetric grid: content 1.05fr, visual 0.95fr.",
        "mobile": "Single-column stack: content first, visual second."
      },
      "rules": [
        "Hero must include one dominant visual anchor.",
        "Hero H1 must use cb-hero-title and remain the strongest type moment.",
        "Hero should show a hint of the next section on common desktop and mobile viewports.",
        "Hero content must not be wrapped in a generic decorative card."
      ]
    },
    "section": {
      "className": "cb-section",
      "variants": [
        "cb-section--compact",
        "cb-section--feature"
      ],
      "rules": [
        "Use standard sections for normal story beats.",
        "Use compact sections for FAQ, metadata, dense proof, or supporting notes.",
        "Use feature sections for key promise, major proof, gallery, or final CTA."
      ]
    },
    "button": {
      "className": "cb-button",
      "rules": [
        "Use for primary course enrollment actions.",
        "Do not resize on hover.",
        "CTA copy must be concrete and short."
      ]
    },
    "reveal": {
      "className": "cb-reveal",
      "rules": [
        "Use on section groups, not every paragraph.",
        "Use data-hero-step for ordered hero entrance.",
        "Respect prefers-reduced-motion."
      ]
    }
  },
  "sectionChoreography": {
    "requiredSequence": [
      "hero",
      "promise",
      "audience tension",
      "method",
      "proof",
      "curriculum",
      "gallery",
      "instructor trust",
      "FAQ",
      "final CTA"
    ],
    "weightMap": {
      "primary": [
        "hero",
        "final CTA"
      ],
      "feature": [
        "promise",
        "method",
        "gallery"
      ],
      "proof": [
        "outcomes",
        "testimonials",
        "student work"
      ],
      "utility": [
        "FAQ",
        "metadata",
        "schedule details"
      ]
    }
  },
  "implementationRules": [
    "Import styles/tokens/course-brand.css before building course landing page components.",
    "Use token names and class names as stable frontend contracts.",
    "Override token values for a specific brand, but do not rename token roles.",
    "Do not invent one-off spacing values when an existing token fits.",
    "Do not add animation before layout hierarchy is clear.",
    "Do not use backend, webhook, or SQL concepts in this design system."
  ]
}
